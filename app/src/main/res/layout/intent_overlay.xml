<?xml version="1.0" encoding="utf-8"?>

<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="320dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="#FFFFFF">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Before you jump in..."
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#000000"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="What are you here for?"
        android:textSize="16sp"
        android:textColor="#444444"/>

    <RadioGroup
        android:id="@+id/reasonGroup"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <RadioButton
            android:id="@+id/replyOption"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Reply Messages"/>

        <RadioButton
            android:id="@+id/workOption"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Work / Study"/>

        <RadioButton
            android:id="@+id/browseOption"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Browse Intentionally"/>
    </RadioGroup>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="How long do you need?"
        android:textSize="16sp"
        android:textColor="#444444"/>

    <RadioGroup
        android:id="@+id/timeGroup"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <RadioButton
            android:id="@+id/fiveMin"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="5 Minutes"/>

        <RadioButton
            android:id="@+id/tenMin"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="10 Minutes"/>

        <RadioButton
            android:id="@+id/fifteenMin"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="15 Minutes"/>
    </RadioGroup>

    <Button
        android:id="@+id/startButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="Start Session"/>

    <Button
        android:id="@+id/skipButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Skip"/>

</LinearLayout>